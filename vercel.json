{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/api/signup", "destination": "/api/signup" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/bella-notify", "destination": "/api/bella-notify" },
    { "source": "/api/bella-schedule-request", "destination": "/api/bella-schedule-request" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

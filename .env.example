# SendGrid (https://app.sendgrid.com → API Keys)
SENDGRID_API_KEY=

# Must be a verified sender in SendGrid (Sender Authentication → Single Sender or Domain)
SENDGRID_FROM_EMAIL=info@digitalmarketrix.com

# Optional “from” display name
SENDGRID_FROM_NAME=Digital Marketrix Website

# Local API port (optional)
API_PORT=3001

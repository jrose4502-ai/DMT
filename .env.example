# Copy to .env or .env.local — never commit real keys (see SendGrid → Settings → API Keys)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@digitalmarketrix.com

# Optional display name on outbound mail
SENDGRID_FROM_NAME=Digital Marketrix Website

# Local API port (optional)
API_PORT=3001

# Groq API key for Bella chat (production)
GROQ_API_KEY=

# Bella: optional extra facts for the AI (hours, industries, promos — multiline ok in Vercel UI)
BELLA_EXTRA_CONTEXT=

# Bella: where chat/transcript & scheduling notification emails go (defaults to SENDGRID recipient / info@)
BELLA_NOTIFY_TO=

# Same Calendly URL Bella mentions (optional override)
BELLA_CALENDLY_URL=https://calendly.com/jrose4502/30min

# Set to 0 to skip auto-reply email when someone submits "Request a specific time"
BELLA_SCHEDULE_VISITOR_COPY=1
